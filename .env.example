FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
BACKEND_URL=http://localhost:8000
# Relative paths resolve against the repo root, never the working directory, so
# this stays correct whether uvicorn starts from the repo root or from backend/.
# The Docker image and compose override it with an absolute /app/data/demo.
DEMO_DATA_DIR=data/demo
# stub    — no model needed. Uses the xBD ground-truth target when a demo pair
#           ships one, otherwise a pre/post difference heuristic.
# docker  — requires the xView2 baseline image built and the Docker daemon up.
# pytorch — requires a fine-tuned checkpoint; the only mode reporting confidence.
INFERENCE_MODE=stub
XVIEW2_DOCKER_IMAGE=darknem-xview2-inference
# Only read when INFERENCE_MODE=pytorch. Relative to the repo root.
PYTORCH_CHECKPOINT_PATH=ml/checkpoints/damage_best.ckpt

# Endpoint protection (both opt-in).
# ACCESS_TOKEN: if set, /analyze, /brief, /report/pdf and /analyze-and-brief
#   require an X-API-Key header matching this value. Leave empty for open access
#   (a browser-only frontend cannot hold a secret, so only enable this behind a
#   server-side proxy or for non-browser clients).
ACCESS_TOKEN=
# Per-IP sliding-window rate limit. Set RATE_LIMIT_REQUESTS=0 to disable.
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
